{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tl-report-builder/sponsorship_widget_schema",
  "title": "Sponsorship widgets (report_type = 8)",
  "description": "Schema for widget objects emitted by Phase 4 for CAMPAIGN_MANAGEMENT (8) reports — sponsorship deal tracking. Defines the per-widget shape, the disjoint sponsorship aggregator catalog, and type-8 axis branching. Pair file: intelligence_widget_schema.json (types 1/2/3).",
  "type": "object",
  "additionalProperties": false,

  "_tl_source_of_truth": {
    "applies_to_report_types": [8],
    "catalog_origin": "v1 system prompt — widget aggregator section for sponsorships reports",
    "catalog_disjoint_with": "intelligence_widget_schema.json — never mix",
    "platform_consumer": "TL dashboard widget renderer; aggregator keys are server-side identifiers"
  },

  "properties": {
    "widgets": {
      "type": "array",
      "minItems": 4,
      "maxItems": 6,
      "description": "Array of widget objects. 4–6 total. First (index: 1) is `count_sponsorships`; histograms occupy the highest indices and use a SHARED axis (send_date OR purchase_date — see _tl_axis_branching).",
      "items": { "$ref": "#/$defs/widget" }
    },
    "histogram_bucket_size": {
      "type": "string",
      "enum": ["week", "month", "year"],
      "description": "Top-level bucket size applied to every histogram in the report."
    }
  },
  "required": ["widgets", "histogram_bucket_size"],

  "$defs": {
    "widget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aggregator": {
          "type": "string",
          "description": "Aggregator key from the sponsorship catalog. See _tl_aggregator_catalog below.",
          "enum": [
            "count_sponsorships",
            "count_sponsorships_over_send_date",
            "count_sponsorships_over_purchase_date",
            "sum_cost", "sum_price",
            "sum_price_over_send_date", "sum_price_over_purchase_date",
            "sum_profit", "sum_impression",
            "count_channels",
            "sum_views", "sum_projected_views",
            "avg_cpv", "sum_conversions", "sum_revenue",
            "avg_cpa", "roas",
            "count_sponsorships_over_performance_grade",
            "count_sponsorships_where_winner",
            "count_sponsorships_where_loser",
            "sum_price_where_winner",
            "sum_price_over_performance_grade",
            "count_sponsorships_where_unpublished",
            "count_sponsorships_where_published",
            "count_sponsorships_where_assets_are_incomplete",
            "count_sponsorships_where_draft_is_missing"
          ]
        },
        "type": {
          "type": "string",
          "enum": ["metrics-box", "histogram", "histogram-category"]
        },
        "index": { "type": "integer", "minimum": 1 },
        "width": { "type": "integer", "enum": [2, 3] },
        "height": { "type": "integer", "const": 1 }
      },
      "required": ["aggregator", "type", "index", "width", "height"]
    }
  },

  "_tl_aggregator_catalog": {
    "core_sponsorships": {
      "count_sponsorships":                    { "type": "metrics-box", "describes": "Total sponsorship count" },
      "count_sponsorships_over_send_date":     { "type": "histogram",   "describes": "Sponsorships scheduled over time", "axis": "send_date" },
      "count_sponsorships_over_purchase_date": { "type": "histogram",   "describes": "Sponsorships purchased over time", "axis": "purchase_date" },
      "sum_cost":                              { "type": "metrics-box", "describes": "Total cost" },
      "sum_price":                             { "type": "metrics-box", "describes": "Total price" },
      "sum_price_over_send_date":              { "type": "histogram",   "describes": "Price scheduled over time", "axis": "send_date" },
      "sum_price_over_purchase_date":          { "type": "histogram",   "describes": "Price purchased over time", "axis": "purchase_date" },
      "sum_profit":                            { "type": "metrics-box", "describes": "Net profit (price - cost). TL profit, not 'margin'." },
      "sum_impression":                        { "type": "metrics-box", "describes": "Total projected views" },
      "count_channels":                        { "type": "metrics-box", "describes": "Unique channels in deal set" }
    },
    "live_ads_tracking": {
      "sum_views":             { "type": "metrics-box", "describes": "Actual views on published ads" },
      "sum_projected_views":   { "type": "metrics-box", "describes": "Projected views at day 30" },
      "avg_cpv":               { "type": "metrics-box", "describes": "Avg cost per view" },
      "sum_conversions":       { "type": "metrics-box", "describes": "Total conversions" },
      "sum_revenue":           { "type": "metrics-box", "describes": "Total revenue (Net revenue)" },
      "avg_cpa":               { "type": "metrics-box", "describes": "Avg cost per acquisition" },
      "roas":                  { "type": "metrics-box", "describes": "Return on ad spend" }
    },
    "performance": {
      "count_sponsorships_over_performance_grade": { "type": "histogram-category", "describes": "Sponsorships by grade" },
      "count_sponsorships_where_winner":           { "type": "metrics-box",        "describes": "Winning sponsorship count" },
      "count_sponsorships_where_loser":            { "type": "metrics-box",        "describes": "Losing sponsorship count" },
      "sum_price_where_winner":                    { "type": "metrics-box",        "describes": "Total price of winners" },
      "sum_price_over_performance_grade":          { "type": "histogram-category", "describes": "Price by grade" }
    },
    "assets_and_drafts": {
      "count_sponsorships_where_unpublished":         { "type": "metrics-box", "describes": "Unpublished count" },
      "count_sponsorships_where_published":           { "type": "metrics-box", "describes": "Published count" },
      "count_sponsorships_where_assets_are_incomplete":{"type": "metrics-box", "describes": "Incomplete assets count" },
      "count_sponsorships_where_draft_is_missing":    { "type": "metrics-box", "describes": "Missing drafts count" }
    }
  },

  "_tl_axis_branching": {
    "description": "Both histograms in a single type-8 report MUST use the SAME axis. Pick by filters_json.publish_status content.",
    "rules": [
      { "publish_status_includes": [0, 2, 6, 7, 8], "axis": "send_date",     "use_aggregators": ["count_sponsorships_over_send_date", "sum_price_over_send_date"], "label": "pipeline view" },
      { "publish_status_only":     [3],             "axis": "purchase_date", "use_aggregators": ["count_sponsorships_over_purchase_date", "sum_price_over_purchase_date"], "label": "won-deals view" },
      { "publish_status_includes_pre_sale_and_sold": true, "axis": "send_date", "label": "mixed pipeline (send_date dominates)" },
      { "performance_grades_present": true, "axis": "purchase_date", "label": "performance view" }
    ]
  },

  "_tl_default_widget_set": [
    { "aggregator": "count_sponsorships",  "type": "metrics-box", "index": 1, "width": 2, "height": 1 },
    { "aggregator": "sum_price",           "type": "metrics-box", "index": 2, "width": 2, "height": 1 },
    { "aggregator": "count_channels",      "type": "metrics-box", "index": 3, "width": 2, "height": 1 },
    { "aggregator": "<count_sponsorships_over_AXIS>", "type": "histogram", "index": 4, "width": 3, "height": 1, "_note": "AXIS branches on publish_status — see _tl_axis_branching" },
    { "aggregator": "<sum_price_over_AXIS>",          "type": "histogram", "index": 5, "width": 3, "height": 1, "_note": "AXIS must match the other histogram's axis" }
  ],

  "_tl_intent_overrides": {
    "pipeline_forecasting": {
      "trigger_phrases": ["pipeline", "forecast", "projected"],
      "axis": "send_date",
      "metrics_emphasis": ["count_sponsorships", "sum_price", "sum_impression"]
    },
    "won_deals_review": {
      "trigger_phrases": ["sold deals", "won deals", "closed deals", "Q1 sold", "this month sold"],
      "axis": "purchase_date",
      "metrics_emphasis": ["count_sponsorships", "sum_price", "sum_revenue", "sum_profit"]
    },
    "performance_roi": {
      "trigger_phrases": ["ROAS", "performance", "winners", "losers"],
      "axis": "purchase_date",
      "swap_one_histogram_to": "count_sponsorships_over_performance_grade",
      "metrics_emphasis": ["roas", "avg_cpv", "sum_revenue"]
    },
    "assets_drafts_qa": {
      "trigger_phrases": ["incomplete", "missing drafts", "assets QA"],
      "drop_histograms": true,
      "metrics_set": [
        "count_sponsorships_where_published",
        "count_sponsorships_where_unpublished",
        "count_sponsorships_where_assets_are_incomplete",
        "count_sponsorships_where_draft_is_missing"
      ]
    }
  },

  "_tl_rules": [
    "Pick 4–6 widgets total. First widget is `count_sponsorships`. Histograms last (highest index).",
    "Every widget MUST add value to the user's original prompt. Don't pad to hit 6 — emit fewer if the extras don't answer something the user implicitly cares about.",
    "Both `_over_AXIS` histograms in the same report use the SAME axis. Pick by `publish_status` per `_tl_axis_branching`.",
    "Never mix this catalog with intelligence_widget_schema.json. Crossing catalogs fails server-side.",
    "Use TL terminology in widget labels: `sum_revenue` is Net revenue; `sum_profit` is TL profit (not 'margin')."
  ]
}
